#!/usr/bin/env bash

# tt — run a turbo task over fzf-selected workspaces.
#
#   tt                   pick the task via fzf, then the packages
#   tt typecheck         pick packages, then run `turbo typecheck`
#   tt unit-test -- ...  trailing args are passed through to turbo
#
# --output-logs=errors-only is always applied (repo convention).

task="${1:-}"
[[ $# -gt 0 ]] && shift

if [[ -z "$task" ]]; then
  task=$(printf '%s\n' typecheck unit-test lint build \
    | fzf --reverse --prompt='turbo task> ') || exit
fi
[[ -n "$task" ]] || exit

# `turbo ls` prints a count header then "<name> <path>" rows; take the name column.
pkgs=$(turbo ls 2>/dev/null | awk 'NR>1 && NF>=2 {print $1}' \
  | fzf --multi --reverse --prompt="$task > " \
        --header='TAB to select multiple · Enter to run') || exit
[[ -n "$pkgs" ]] || exit

args=()
while IFS= read -r pkg; do
  args+=(-F "$pkg")
done <<< "$pkgs"

set -- "$task" "${args[@]}" --output-logs=errors-only "$@"
printf '\033[1;34m$ turbo %s\033[0m\n' "$*"
turbo "$@"
