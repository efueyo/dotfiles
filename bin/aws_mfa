#!/bin/bash

# Configure AWS temporary credentials using MFA
# Usage: aws_mfa [source_profile] [mfa_profile]
#
# Examples:
#   aws_mfa              # interactive: pick source profile with fzf
#   aws_mfa default mfa  # use 'default' creds, write to 'mfa' profile

set -euo pipefail

CREDENTIALS_FILE="${AWS_SHARED_CREDENTIALS_FILE:-$HOME/.aws/credentials}"

# Get source profile (the one with long-lived keys)
if [[ -n "${1:-}" ]]; then
  SOURCE_PROFILE="$1"
else
  SOURCE_PROFILE=$(aws configure list-profiles | fzf --reverse --height 40% --prompt="Source profile (with long-lived keys): ")
fi

# Get target profile name for the MFA credentials
if [[ -n "${2:-}" ]]; then
  MFA_PROFILE="$2"
else
  read -rp "MFA profile name to write to [mfa]: " MFA_PROFILE
  MFA_PROFILE="${MFA_PROFILE:-mfa}"
fi

# Get the MFA device ARN
MFA_SERIAL=$(aws iam list-mfa-devices --profile "$SOURCE_PROFILE" --query 'MFADevices[0].SerialNumber' --output text)

if [[ -z "$MFA_SERIAL" || "$MFA_SERIAL" == "None" ]]; then
  echo "Error: No MFA device found for profile '$SOURCE_PROFILE'"
  exit 1
fi

echo "MFA device: $MFA_SERIAL"

# Prompt for MFA token (type 'bw' to fetch TOTP from Bitwarden)
read -rp "Enter MFA token code (or 'bw'): " TOKEN_CODE

if [[ "$TOKEN_CODE" == "bw" ]]; then
  if ! command -v bw &> /dev/null; then
    echo "Error: Bitwarden CLI not found."
    exit 1
  fi
  if ! bw unlock --check &> /dev/null; then
    echo "Unlock the vault first..."
    BW_SESSION=$(bw unlock --raw)
    if [[ -z "$BW_SESSION" ]]; then
      echo "Error: Failed to unlock Bitwarden vault."
      exit 1
    fi
    export BW_SESSION
  fi
  items=$(bw list items)
  selected_id=$(echo "$items" |
    jq -r '.[] | "\(.id)\t\(.name)"' |
    fzf --reverse --height 40% --with-nth=2 |
    awk '{print $1}'
  )
  [[ -z "$selected_id" ]] && exit 0
  TOKEN_CODE=$(bw get totp "$selected_id")
  echo "TOTP code retrieved from Bitwarden"
fi

# Get temporary session credentials
CREDS=$(aws sts get-session-token \
  --profile "$SOURCE_PROFILE" \
  --serial-number "$MFA_SERIAL" \
  --token-code "$TOKEN_CODE" \
  --output json)

ACCESS_KEY=$(echo "$CREDS" | jq -r '.Credentials.AccessKeyId')
SECRET_KEY=$(echo "$CREDS" | jq -r '.Credentials.SecretAccessKey')
SESSION_TOKEN=$(echo "$CREDS" | jq -r '.Credentials.SessionToken')
EXPIRATION=$(echo "$CREDS" | jq -r '.Credentials.Expiration')

# Write credentials to the MFA profile
aws configure set aws_access_key_id "$ACCESS_KEY" --profile "$MFA_PROFILE"
aws configure set aws_secret_access_key "$SECRET_KEY" --profile "$MFA_PROFILE"
aws configure set aws_session_token "$SESSION_TOKEN" --profile "$MFA_PROFILE"

echo "Credentials written to profile '$MFA_PROFILE'"
echo "Expires: $EXPIRATION"
